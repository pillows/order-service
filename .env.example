# Polymarket order-execution service configuration.
# This file lives on the DEDICATED ORDER HOST, not with the dashboard. It is the
# only place the trading wallet key should exist.

# Shared secret the dashboard must present as `Authorization: Bearer <token>`.
# REQUIRED — without it every trading endpoint returns 503. Use a long random
# value (e.g. `openssl rand -hex 32`) and set the SAME value on the dashboard's
# ORDER_SERVICE_TOKEN.
ORDER_SERVICE_TOKEN=

# Trading wallet. The service derives CLOB API creds from this key and signs
# orders with it. signature_type: 0=EOA, 1=email/magic proxy, 2=browser-wallet
# proxy. For a proxy (1/2), POLYMARKET_ADDRESS is the funder/proxy that holds
# collateral and is REQUIRED.
POLYMARKET_WALLET_PRIVATE_KEY=0x...
POLYMARKET_ADDRESS=0x...
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# HTTP port the app listens on inside the container (default 8070).
# PORT=8070

# docker-compose port publishing (see docker-compose.yml):
#   ORDER_SERVICE_PORT — published host port (default 8070)
#   ORDER_SERVICE_BIND — host interface to bind (default 0.0.0.0; pin to a
#                        private/VPN IP in production).
# ORDER_SERVICE_PORT=8070
# ORDER_SERVICE_BIND=0.0.0.0
